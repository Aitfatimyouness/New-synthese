# Root-level generated files
.DS_Store
Thumbs.db

# Local environment files
.env
.env.*
!.env.example

# Dependencies and builds
node_modules/
vendor/
build/
public/build/

# Laravel generated/runtime data
project-santi/database/*.sqlite
project-santi/storage/app/*
