project-santi/storage/framework/testing/*
project-santi/storage/framework/views/*
project-santi/storage/logs/*
!project-santi/storage/app/.gitignore
!project-santi/storage/framework/cache/.gitignore
!project-santi/storage/framework/sessions/.gitignore
!project-santi/storage/framework/testing/.gitignore
!project-santi/storage/framework/views/.gitignore
!project-santi/storage/logs/.gitignore

